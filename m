-		printf("PAN stop Alarm was received\n");
-		rec_signal = SIGTERM;
-	}
-
-	for (i = 0; i < keep_active; ++i) {
-		if (running[i].pgrp == 0)
-			continue;
-
-		if (Debug & Dshutdown)
-			fprintf(stderr, "  propagating sig %d to %d\n",
