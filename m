-	buf = malloc(sbuf.st_size + 1);
-	if (read(fd, buf, sbuf.st_size) != sbuf.st_size) {
-		fprintf(stderr, "pan(%s): slurp failed.  errno:%d  %s\n",
-			panname, errno, strerror(errno));
-		free(buf);
-		return NULL;
