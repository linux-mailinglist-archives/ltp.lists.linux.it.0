-static char *slurp(char *file)
-{
-	char *buf;
-	int fd;
-	struct stat sbuf;
-
-	if ((fd = open(file, O_RDONLY)) < 0) {
-		fprintf(stderr,
-			"pan(%s): open(%s,O_RDONLY) failed.  errno:%d  %s\n",
-			panname, file, errno, strerror(errno));
-		return NULL;
-	}
-
-	if (fstat(fd, &sbuf) < 0) {
-		fprintf(stderr, "pan(%s): fstat(%s) failed.  errno:%d  %s\n",
