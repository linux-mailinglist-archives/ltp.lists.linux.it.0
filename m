-			if (errno == ESRCH) {
-				/* This pgrp is now empty */
-				if (zoo_clear(zoofile, orph->pgrp)) {
-					fprintf(stderr, "pan(%s): %s\n",
-						panname, zoo_error);
-				}
-				orph->pgrp = 0;
-			} else {
-				fprintf(stderr,
-					"pan(%s): kill(%d,%d) on orphaned pgrp failed.  errno:%d  %s\n",
-					panname, -(orph->pgrp), sig, errno,
-					strerror(errno));
